--Task 3: Create a function that takes a country as an input parameter 
--and returns the most popular film in that specific country. 

--Creating or replacing the function
CREATE OR REPLACE FUNCTION public.most_popular_films_by_countries(countries TEXT[])
RETURNS TABLE (country_name TEXT, most_popular_film_name TEXT) AS $$
BEGIN
    -- Ensure the input array is not empty
    IF array_length(countries, 1) IS NULL THEN
        RAISE EXCEPTION 'The array of countries cannot be empty.';
    END IF;

    RETURN QUERY

    SELECT DISTINCT ON (co.country) 
        co.country AS country_name,
        f.title AS most_popular_film_name
    FROM country co
    INNER JOIN city ci ON co.country_id = ci.country_id
    INNER JOIN address a ON ci.city_id = a.city_id
    INNER JOIN customer cu ON a.address_id = cu.address_id
    INNER JOIN rental r ON cu.customer_id = r.customer_id
    INNER JOIN inventory i ON r.inventory_id = i.inventory_id
    INNER JOIN film f ON i.film_id = f.film_id
	-- Filtering by the input array of countries
    WHERE co.country = ANY (countries)
    GROUP BY co.country, f.title
    ORDER BY co.country, COUNT(r.rental_id) DESC;

    RAISE NOTICE 'Function executed successfully for input countries: %.', countries;
END;
$$ LANGUAGE plpgsql;


