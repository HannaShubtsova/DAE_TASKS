
-- Task 1: Create a view called 'sales_revenue_by_category_qtr' that shows the film category and total 
--sales revenue for the current quarter and year. 
--The view should only display categories with at least one sale in the current quarter. 


-- Creating the view
CREATE OR replace VIEW public.sales_revenue_by_category_qtr AS
SELECT 
    c.name AS category_name, 
    SUM(p.amount) AS total_revenue  -- Total revenue (from payments)
FROM 
    category c
INNER JOIN film_category fc ON c.category_id = fc.category_id
INNER JOIN film f ON fc.film_id = f.film_id
INNER JOIN 
    inventory i ON f.film_id = i.film_id
INNER JOIN 
    rental r ON i.inventory_id = r.inventory_id
INNER JOIN 
    payment p ON r.rental_id = p.rental_id
WHERE 
    -- Filtering for the current year and quarter using EXTRACT
    EXTRACT(YEAR FROM p.payment_date) = EXTRACT(YEAR FROM CURRENT_DATE)
    AND EXTRACT(QUARTER FROM p.payment_date) = EXTRACT(QUARTER FROM CURRENT_DATE)
GROUP BY 
    c.name 
HAVING 
    -- Include only categories with revenue
    SUM(p.amount) > 0;
   
--testing by selecting
  SELECT * FROM sales_revenue_by_category_qtr;
 
 
 --Task 2:Create a query language function called 'get_sales_revenue_by_category_qtr' 
 --that accepts one parameter representing the current quarter and year and returns the same result as the 
 --'sales_revenue_by_category_qtr' view.
 
 --creating or replacing the function
CREATE OR REPLACE FUNCTION public.get_sales_revenue_by_category_qtr(target_quarter INTEGER, target_year INTEGER)
RETURNS TABLE (category_name TEXT, total_revenue NUMERIC) AS $$
BEGIN
    -- Ensuring the quarter is valid
    IF target_quarter NOT BETWEEN 1 AND 4 THEN 
        RAISE EXCEPTION 'Invalid quarter: %; Quarter must be between 1 and 4', target_quarter;
    END IF;

    -- Ensuring the year is valid
    IF target_year < 1 OR target_year > EXTRACT(YEAR FROM CURRENT_DATE) THEN
        RAISE EXCEPTION 'Invalid year: %; Year must be greater than 0 and less than or equal to the current year', target_year;
    END IF;

    -- Returning the query results
    RETURN QUERY
    SELECT c.name AS category_name,
           SUM(COALESCE(p.amount, 0)) AS total_revenue
    FROM category c
    INNER JOIN film_category fc ON c.category_id = fc.category_id
    INNER JOIN film f ON fc.film_id = f.film_id
    INNER JOIN inventory i ON f.film_id = i.film_id
    INNER JOIN rental r ON i.inventory_id = r.inventory_id
    INNER JOIN payment p ON r.rental_id = p.rental_id
    WHERE EXTRACT(YEAR FROM p.payment_date) = target_year
      AND EXTRACT(QUARTER FROM p.payment_date) = target_quarter
    GROUP BY c.name
    HAVING SUM(p.amount) > 0;

    -- Logging the execution for debugging purposes
    RAISE NOTICE 'Function executed successfully for quarter % of year %.', target_quarter, target_year;
END;
$$ LANGUAGE plpgsql;

